---
import MainLayout from '../layouts/MainLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { getDictionary, localePath, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const dict = getDictionary(locale);
const detailPages = new Set(['openpr', 'prx', 'prx-memory']);

const productIcon: Record<string, string> = {
  openpr: 'OPR',
  prx: 'PRX',
  'prx-memory': 'MEM',
};
---

<MainLayout title={dict.meta.homeTitle} description={dict.meta.homeDescription} locale={locale} path="/">
  <SiteHeader locale={locale} dict={dict} path="/" />

  <main>
    <section class="container-shell pt-16 pb-14 reveal">
      <div class="panel relative overflow-hidden px-6 py-10 md:px-10 md:py-14">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,color-mix(in_oklab,var(--brand)_32%,transparent),transparent_42%)]"></div>
        <div class="relative z-10 max-w-3xl">
          <p class="mono-pill text-xs uppercase tracking-[0.18em] text-[var(--brand-strong)]">{dict.hero.eyebrow}</p>
          <div class="mt-6 mb-5">
            <img src="/brand-assets/logo-full.svg" alt="OpenPRX" class="h-12 w-auto logo-dark" />
            <img src="/brand-assets/logo-full-light.svg" alt="OpenPRX" class="h-12 w-auto logo-light" />
          </div>
          <h1 class="section-title">{dict.hero.title}</h1>
          <p class="mt-4 text-xl text-[var(--text)]">{dict.hero.subtitle}</p>
          <p class="mt-4 max-w-2xl text-base text-[var(--text-dim)]">{dict.hero.description}</p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href="https://github.com/openprx"
              target="_blank"
              rel="noreferrer"
              class="rounded-md border border-[var(--border)] bg-[var(--bg-soft)] px-4 py-2 text-sm text-[var(--text-dim)] hover:text-[var(--text)]"
            >
              {dict.hero.githubCta}
            </a>
            <a href="#products" class="glow rounded-md bg-[var(--brand)] px-4 py-2 text-sm font-semibold text-white">
              {dict.hero.primaryCta}
            </a>
          </div>
        </div>
      </div>
    </section>

    <section id="products" class="container-shell pb-14 reveal">
      <div class="mb-6">
        <h2 class="section-title">{dict.products.title}</h2>
        <p class="mt-2 text-[var(--text-dim)]">{dict.products.description}</p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {dict.products.items.map((item) => {
          const detailLink = detailPages.has(item.id) ? localePath(locale, `/${item.id}`) : item.repo;
          const external = !detailPages.has(item.id);
          return (
            <article class="panel h-full p-5 transition-transform duration-300 hover:-translate-y-0.5">
              <div class="flex items-center justify-between gap-3">
                <span class="mono-pill rounded-md border border-[var(--border)] bg-[var(--bg-soft)] px-2.5 py-1 text-xs text-[var(--brand-strong)]">
                  {productIcon[item.id] ?? 'PRX'}
                </span>
                <a
                  href={item.repo}
                  target="_blank"
                  rel="noreferrer"
                  class="text-xs text-[var(--text-dim)] hover:text-[var(--text)]"
                >
                  GitHub
                </a>
              </div>

              <h3 class="mt-4 text-lg font-semibold">{item.name}</h3>
              <p class="text-sm text-[var(--brand-strong)]">{item.tagline}</p>
              <p class="mt-3 text-sm text-[var(--text-dim)]">{item.description}</p>

              <a
                href={detailLink}
                target={external ? '_blank' : undefined}
                rel={external ? 'noreferrer' : undefined}
                class="mt-5 inline-flex rounded-md border border-[var(--border)] px-3 py-1.5 text-sm text-[var(--text-dim)] hover:text-[var(--text)]"
              >
                {external ? dict.header.github : dict.header.getStarted}
              </a>
            </article>
          );
        })}
      </div>
    </section>

    <section class="container-shell pb-8 reveal">
      <div class="mb-6">
        <h2 class="section-title">{dict.features.title}</h2>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        {dict.features.items.map((feature) => (
          <article class="panel p-5">
            <h3 class="text-base font-semibold">{feature.title}</h3>
            <p class="mt-2 text-sm text-[var(--text-dim)]">{feature.description}</p>
          </article>
        ))}
      </div>
    </section>
  </main>

  <SiteFooter locale={locale} dict={dict} path="/" />
</MainLayout>

<style>
  .logo-light {
    display: none;
  }

  html[data-theme='light'] .logo-light {
    display: block;
  }

  html[data-theme='light'] .logo-dark {
    display: none;
  }
</style>
