---
import MainLayout from '../layouts/MainLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import Icon from '../components/Icon.astro';
import { getDictionary, localePath, type Locale } from '../i18n';

interface Props {
  locale: Locale;
  product: 'openpr' | 'prx' | 'prx-memory' | 'prx-sd' | 'prx-waf' | 'fenfa';
}

const { locale, product } = Astro.props;
const dict = getDictionary(locale);
const page = dict.pages[product];
const arch = page.architecture as Record<string, string>;
const related = dict.products.items.filter((item) => item.id !== product);

const titleByProduct: Record<string, string> = {
  openpr: dict.meta.openprTitle,
  prx: dict.meta.prxTitle,
  'prx-memory': dict.meta.memoryTitle,
  'prx-sd': dict.meta.prxSdTitle,
  'prx-waf': dict.meta.prxWafTitle,
  fenfa: dict.meta.fenfaTitle
};

const descByProduct: Record<string, string> = {
  openpr: dict.meta.openprDescription,
  prx: dict.meta.prxDescription,
  'prx-memory': dict.meta.memoryDescription,
  'prx-sd': dict.meta.prxSdDescription,
  'prx-waf': dict.meta.prxWafDescription,
  fenfa: dict.meta.fenfaDescription
};

const path = `/${product}`;
const repoPath = page.repo.replace('https://github.com/', '');
const starsBadge = `https://img.shields.io/github/stars/${repoPath}?style=for-the-badge&logo=github&label=${encodeURIComponent(dict.common.star)}&color=6366f1`;

const stageIndexByProduct: Record<string, number> = {
  openpr: 0, prx: 1, 'prx-memory': 2, 'prx-sd': 4, 'prx-waf': 4, fenfa: 3
};
const currentStageIndex = stageIndexByProduct[product] ?? -1;
const stages = dict.pipeline.stages;
---

<MainLayout title={titleByProduct[product]} description={descByProduct[product]} locale={locale} path={path}>
  <SiteHeader locale={locale} dict={dict} path={path} />

  <main class="container-shell pt-16 pb-12">
    <nav class="pipeline-breadcrumb mb-6 reveal" aria-label="Pipeline position">
      {stages.map((stage, i) => (
        <>
          {i === currentStageIndex ? (
            <span class="pipeline-crumb pipeline-crumb-active">{stage.name}</span>
          ) : (
            <a href={localePath(locale, stage.href)} class="pipeline-crumb">{stage.name}</a>
          )}
          {i < stages.length - 1 && <span class="pipeline-crumb-sep" aria-hidden="true">&#8594;</span>}
        </>
      ))}
    </nav>

    <section class="panel px-6 py-10 md:px-10 md:py-12 reveal">
      <p class="mono-pill text-xs uppercase tracking-[0.18em] text-[var(--brand-strong)]">{dict.meta.siteName}</p>
      <h1 class="section-title mt-4">{page.name}</h1>
      <p class="mt-3 text-lg text-[var(--brand-strong)]">{page.tagline}</p>
      <p class="mt-4 max-w-3xl text-[var(--text-dim)]">{page.description}</p>

      <div class="mt-6 flex flex-wrap items-center gap-3">
        <span class="inline-flex items-center rounded-full border border-[var(--border)] bg-[var(--bg-soft)] px-3 py-1 text-xs text-[var(--text-dim)]">
          <span class="text-[var(--brand-strong)]">{dict.common.languageBadge}:</span>&nbsp;{page.language}
        </span>
        <span class="inline-flex items-center rounded-full border border-[var(--border)] bg-[var(--bg-soft)] px-3 py-1 text-xs text-[var(--text-dim)]">
          <span class="text-[var(--brand-strong)]">{dict.common.licenseBadge}:</span>&nbsp;{page.license}
        </span>
        <a href={page.repo} target="_blank" rel="noreferrer" class="rounded-md">
          <img src={starsBadge} alt={`${page.name} ${dict.common.star}`} loading="lazy" />
        </a>
      </div>

      <div class="mt-7 flex flex-wrap gap-3">
        <a
          href={`https://docs.openprx.dev/en/${product}/`}
          target="_blank"
          rel="noreferrer"
          class="glow rounded-md bg-[var(--brand)] px-4 py-2 text-sm font-semibold text-white"
        >
          {dict.common.docs}
        </a>
        <a
          href={page.repo}
          target="_blank"
          rel="noreferrer"
          class="rounded-md border border-[var(--border)] bg-[var(--bg-soft)] px-4 py-2 text-sm text-[var(--text-dim)] hover:text-[var(--text)]"
        >
          {dict.common.repository}
        </a>
      </div>
    </section>

    <section class="mt-8 panel p-6 md:p-8 reveal">
      <h2 class="section-title text-2xl">{dict.common.keyFeatures}</h2>
      <div class="mt-5 grid gap-4 md:grid-cols-2">
        {page.features.map((feature) => (
          <article class="soft-border rounded-xl bg-[color-mix(in_oklab,var(--bg-soft)_88%,transparent)] p-4">
            <h3 class="text-base font-semibold">
              <Icon name={feature.icon} size={18} class="inline-block mr-1.5 text-[var(--brand-strong)] -mt-0.5" />
              {feature.title}
            </h3>
            <p class="mt-2 text-sm text-[var(--text-dim)]">{feature.description}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="mt-8 panel p-6 md:p-8 reveal">
      <h2 class="section-title text-2xl">{dict.common.architecture}</h2>

      {product === 'openpr' && (
        <div class="mt-5 architecture-shell">
          <div class="flow-row flow-row-top">
            <div class="arch-box">{arch.browser}</div>
            <span class="flow-arrow">→</span>
            <div class="arch-box">{arch.frontend}</div>
            <span class="flow-arrow">→</span>
            <div class="arch-box">{arch.api}</div>
            <span class="flow-arrow">→</span>
            <div class="arch-box">{arch.database}</div>
          </div>

          <div class="flow-column">
            <span class="flow-arrow">↕</span>
            <div class="arch-box arch-box-wide">
              <strong>{arch.mcp}</strong>
              <p>{arch.transports}</p>
            </div>
          </div>
        </div>
      )}

      {product === 'prx' && (
        <div class="mt-5 architecture-shell">
          <div class="prx-grid">
            <article class="arch-box left-align">
              <h3>{arch.channelsTitle}</h3>
              <p>{arch.channelsList}</p>
            </article>
            <article class="arch-box left-align">
              <h3>{arch.providersTitle}</h3>
              <p>{arch.providersList}</p>
            </article>
          </div>

          <div class="flow-column">
            <span class="flow-arrow">↓</span>
            <article class="arch-box arch-box-wide">
              <h3>{arch.coreTitle}</h3>
              <p>{arch.coreLineOne}</p>
              <p>{arch.coreLineTwo}</p>
            </article>
          </div>
        </div>
      )}

      {product === 'prx-memory' && (
        <div class="mt-5 architecture-shell flow-column">
          <article class="arch-box arch-box-wide">
            <h3>{arch.agents}</h3>
          </article>
          <span class="flow-arrow">↓ {arch.mcp}</span>
          <article class="arch-box arch-box-wide">
            <h3>{arch.coreTitle}</h3>
            <p>{arch.coreLineOne}</p>
            <p>{arch.coreLineTwo}</p>
          </article>
          <span class="flow-arrow">↓</span>
          <article class="arch-box arch-box-wide">
            <h3>{arch.storage}</h3>
          </article>
        </div>
      )}

      {product === 'prx-sd' && (
        <div class="mt-5 architecture-shell flow-column">
          <article class="arch-box arch-box-wide">
            <h3>{arch.input}</h3>
          </article>
          <span class="flow-arrow">↓</span>
          <div class="flow-row">
            <div class="arch-box"><h3>{arch.hash}</h3><p>{arch.hashDesc}</p></div>
            <span class="flow-arrow">→</span>
            <div class="arch-box"><h3>{arch.yara}</h3><p>{arch.yaraDesc}</p></div>
            <span class="flow-arrow">→</span>
            <div class="arch-box"><h3>{arch.heuristic}</h3><p>{arch.heuristicDesc}</p></div>
          </div>
          <span class="flow-arrow">↓</span>
          <article class="arch-box arch-box-wide">
            <h3>{arch.result}</h3>
          </article>
        </div>
      )}

      {product === 'prx-waf' && (
        <div class="mt-5 architecture-shell">
          <div class="flow-row flow-row-top">
            <div class="arch-box">{arch.client}</div>
            <span class="flow-arrow">→</span>
            <div class="arch-box">{arch.proxy}</div>
            <span class="flow-arrow">→</span>
            <div class="arch-box">{arch.backend}</div>
          </div>
          <div class="flow-column">
            <span class="flow-arrow">↕</span>
            <article class="arch-box arch-box-wide">
              <strong>{arch.engine}</strong>
              <p>{arch.phases}</p>
            </article>
          </div>
        </div>
      )}

      {product === 'fenfa' && (
        <div class="mt-5 architecture-shell flow-column">
          <article class="arch-box arch-box-wide">
            <h3>{arch.upload}</h3>
          </article>
          <span class="flow-arrow">↓</span>
          <article class="arch-box arch-box-wide">
            <h3>{arch.processing}</h3>
            <p>{arch.processingDesc}</p>
          </article>
          <span class="flow-arrow">↓</span>
          <article class="arch-box arch-box-wide">
            <h3>{arch.distribution}</h3>
            <p>{arch.distributionDesc}</p>
          </article>
        </div>
      )}
    </section>

    <section class="mt-8 panel p-6 md:p-8 reveal">
      <h2 class="section-title text-2xl">{dict.common.techStack}</h2>
      <p class="mt-4 rounded-lg bg-[var(--bg-soft)] px-3 py-2 code-font text-sm text-[var(--text)]">{page.tech}</p>

      <h2 class="section-title mt-8 text-2xl">{dict.common.quickStart}</h2>
      <pre class="mt-4 overflow-x-auto rounded-lg bg-[var(--code-bg)] p-4 text-xs text-[#d2d9ff]"><code class="code-font">{page.quickStart.join('\n')}</code></pre>
    </section>

    <section class="mt-8 panel p-6 md:p-8 reveal">
      <h2 class="section-title text-2xl">{dict.common.alsoFrom}</h2>
      <div class="mt-5 grid gap-4 md:grid-cols-2">
        {related.map((item) => (
          <article class="soft-border rounded-xl bg-[color-mix(in_oklab,var(--bg-soft)_88%,transparent)] p-4">
            <h3 class="text-base font-semibold">{item.name}</h3>
            <p class="mt-1 text-sm text-[var(--brand-strong)]">{item.tagline}</p>
            <p class="mt-2 text-sm text-[var(--text-dim)]">{item.description}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {item.highlights.map((tag) => (
                <span class="rounded-full border border-[var(--border)] bg-[var(--bg-soft)] px-2.5 py-1 text-xs text-[var(--text-dim)]">
                  {tag}
                </span>
              ))}
            </div>
            <a
              href={localePath(locale, `/${item.id}`)}
              class="mt-4 inline-flex rounded-md border border-[var(--border)] px-3 py-1.5 text-sm text-[var(--text-dim)] hover:text-[var(--text)]"
            >
              {dict.common.learnMore}
            </a>
          </article>
        ))}
      </div>
    </section>

    <div class="mt-8 reveal">
      <a href={localePath(locale, '/')} class="rounded-md border border-[var(--border)] px-4 py-2 text-sm text-[var(--text-dim)] hover:text-[var(--text)]">
        {dict.common.backHome}
      </a>
    </div>
  </main>

  <SiteFooter locale={locale} dict={dict} path={path} />
</MainLayout>

<style>
  .architecture-shell {
    border: 1px solid var(--border);
    border-radius: 1rem;
    background: color-mix(in oklab, var(--bg-soft) 84%, transparent);
    padding: 1rem;
  }

  .flow-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
  }

  .flow-row-top {
    margin-bottom: 0.75rem;
  }

  .flow-column {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.6rem;
  }

  .flow-arrow {
    font-size: 0.92rem;
    color: var(--brand-strong);
  }

  .arch-box {
    border: 1px solid var(--border);
    border-radius: 0.85rem;
    background: var(--bg-elev);
    padding: 0.8rem 0.95rem;
    text-align: center;
    font-size: 0.85rem;
    min-width: 120px;
  }

  .arch-box h3 {
    margin: 0;
    font-size: 0.9rem;
  }

  .arch-box p {
    margin: 0.35rem 0 0;
    color: var(--text-dim);
    font-size: 0.8rem;
  }

  .arch-box-wide {
    min-width: min(540px, 100%);
  }

  .left-align {
    text-align: left;
  }

  .prx-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
    align-items: stretch;
    margin-bottom: 0.9rem;
  }

  @media (max-width: 760px) {
    .arch-box-wide {
      min-width: 100%;
    }

    .prx-grid {
      grid-template-columns: 1fr;
    }
  }

  .pipeline-breadcrumb {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.4rem;
  }

  .pipeline-crumb {
    padding: 0.3rem 0.7rem;
    border-radius: 0.5rem;
    font-size: 0.78rem;
    color: var(--text-dim);
    text-decoration: none;
    transition: color 0.15s, background 0.15s;
  }

  .pipeline-crumb:hover {
    color: var(--text);
    background: var(--bg-soft);
  }

  .pipeline-crumb-active {
    background: color-mix(in oklab, var(--brand) 18%, transparent);
    color: var(--brand-strong);
    font-weight: 600;
  }

  .pipeline-crumb-sep {
    font-size: 0.7rem;
    color: var(--brand-strong);
    opacity: 0.5;
  }
</style>
